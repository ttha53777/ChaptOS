generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// The tenant. One row per chapter (or any org). All domain rows carry a FK here.
model Organization {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())

  memberships        Membership[]
  brothers           Brother[]
  roles              Role[]
  semesters          Semester[]
  calendarEvents     CalendarEvent[]
  serviceEvents      ServiceEvent[]
  partyEvents        PartyEvent[]
  deadlines          Deadline[]
  instagramTasks     InstagramTask[]
  docs               Doc[]
  transactions       Transaction[]
  budgets            Budget[]
  activityLogs       ActivityLog[]
  announcements      ChapterAnnouncement[]
  operationalEvents  OperationalEvent[]
}

// Links a Brother (Supabase identity + profile) to an Organization.
// isOrgAdmin replaces Brother.isAdmin for per-org admin authority.
model Membership {
  id             Int          @id @default(autoincrement())
  brotherId      Int
  organizationId Int
  isOrgAdmin     Boolean      @default(false)
  joinedAt       DateTime     @default(now())

  brother      Brother      @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([brotherId, organizationId])
  @@index([organizationId])
}

// Platform-level super-admin (you, support staff). Distinct from per-org isOrgAdmin.
// Replaces the Brother.isAdmin boolean for platform-staff access.
model PlatformAdmin {
  id        Int     @id @default(autoincrement())
  brotherId Int     @unique
  brother   Brother @relation(fields: [brotherId], references: [id])
}

model Brother {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  name              String
  role              String
  attendance        Float
  duesOwed          Float
  gpa               Float
  serviceHours      Float
  authUserId        String?            @unique @map("auth_user_id")
  avatarUrl         String?            @map("avatar_url")
  email             String?
  isAdmin           Boolean            @default(false)
  // "Ghost" members provisioned via the Atomic Samurai backdoor: full app access
  // but hidden from every brother listing, count, and attendance enrollment.
  isGhost           Boolean            @default(false)
  attendanceRecords AttendanceRecord[]
  attendanceExcuses AttendanceExcuse[]
  authoredLogs      ActivityLog[]
  roles             BrotherRole[]
  memberships       Membership[]
  platformAdmin     PlatformAdmin?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// Discord-style role: a named bundle of permission bits with a hierarchy rank.
// name is unique per org (not globally) — two orgs may both have a "President" role.
model Role {
  id             Int           @id @default(autoincrement())
  organizationId Int
  name           String
  // Optional hex color (e.g. "#5865F2") for the UI chip; null = neutral.
  color          String?
  // Hierarchy rank. A caller can only grant/edit roles whose rank is STRICTLY
  // LESS than their own highest assigned role's rank. Higher = more authority.
  rank           Int           @default(0)
  // Bitfield of PERMISSIONS flags (see lib/permissions.ts).
  permissions    Int           @default(0)
  // System roles are seeded by migration and protected from deletion/rename.
  isSystem       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  brothers       BrotherRole[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@index([organizationId, rank])
}

// Join table: a brother can hold any number of roles. Their effective
// permission bitfield is the bitwise OR of every assigned role's `permissions`.
model BrotherRole {
  brotherId  Int
  roleId     Int
  assignedAt DateTime @default(now())
  brother    Brother  @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([brotherId, roleId])
  @@index([roleId])
}

model Semester {
  id             Int                @id @default(autoincrement())
  organizationId Int
  label          String
  startDate      String
  endDate        String
  isActive       Boolean            @default(false)
  records        AttendanceRecord[]
  excuses        AttendanceExcuse[]
  transactions   Transaction[]
  budgets        Budget[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, label])
  @@index([organizationId, isActive])
}

model AttendanceRecord {
  id              Int           @id @default(autoincrement())
  calendarEventId Int
  brotherId       Int
  semesterId      Int
  attended        Boolean
  loggedAt        DateTime      @default(now())
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id])
  brother         Brother       @relation(fields: [brotherId], references: [id])
  semester        Semester      @relation(fields: [semesterId], references: [id])

  @@unique([calendarEventId, brotherId])
  @@index([brotherId, semesterId])
  @@index([calendarEventId, semesterId])
}

model AttendanceExcuse {
  id              Int           @id @default(autoincrement())
  calendarEventId Int
  brotherId       Int
  semesterId      Int
  reason          String
  submittedAt     DateTime      @default(now())
  isRetroactive   Boolean       @default(false)
  status          String        @default("approved")
  decidedById     Int?
  decidedAt       DateTime?
  rejectionNote   String?
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id])
  brother         Brother       @relation(fields: [brotherId], references: [id])
  semester        Semester      @relation(fields: [semesterId], references: [id])

  @@unique([calendarEventId, brotherId])
  @@index([brotherId, semesterId])
  @@index([calendarEventId, semesterId])
  @@index([status])
}

model Deadline {
  id             Int    @id @default(autoincrement())
  organizationId Int
  title          String
  dueDate        String
  owner          String
  status         String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model InstagramTask {
  id             Int    @id @default(autoincrement())
  organizationId Int
  title          String
  dueDate        String
  owner          String
  status         String
  type           String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// A pinned external resource (Google Doc, website, shared drive folder, …)
// shown on the Docs page. We cache OG metadata so cards can fall back to a
// thumbnail when the destination refuses to load in an iframe.
model Doc {
  id             Int      @id @default(autoincrement())
  organizationId Int
  title          String
  url            String
  description    String?
  // Cached metadata, refreshed on create / URL change. `embedOk = null` means
  // we haven't probed yet; `false` means the site sent X-Frame-Options or a
  // frame-ancestors CSP that blocks our origin → render the OG image instead.
  ogImage        String?
  ogTitle        String?
  faviconUrl     String?
  embedOk        Boolean?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    Int?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
}

model PartyEvent {
  id             Int       @id @default(autoincrement())
  organizationId Int
  name           String
  date           String
  partyType      String    @default("Open")
  theme          String    @default("")
  collabOrg      String    @default("")
  doorRevenue    Float     @default(0)
  attendance     Int       @default(0)
  expenses       Float     @default(0)
  notes          String    @default("")
  completed      Boolean   @default(false)
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model CalendarEvent {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  title             String
  date              String
  time              String?
  category          String
  mandatory         Boolean
  description       String?
  location          String?
  notesSummary      String?
  notesSummaryAt    DateTime?
  notesUpdatedAt    DateTime?
  attendanceRecords AttendanceRecord[]
  attendanceExcuses AttendanceExcuse[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, category, date])
}

model ServiceEvent {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  title           String
  date            String
  location        String   @default("")
  notes           String   @default("")
  calendarEventId Int?     @unique
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  organizationId Int
  message        String
  type           String
  timestamp      DateTime @default(now())
  actorId        Int?
  actor          Brother? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
  @@index([actorId])
}

// Structured operational event log. The raw fact-stream from which the UI
// activity feed, audit log, analytics, notifications, and AI context are
// projected. Free-text ActivityLog rows are dual-written from logActivity()
// for backwards-compat until Phase 3 cuts the UI over to event projections.
model OperationalEvent {
  id             BigInt   @id @default(autoincrement())
  organizationId Int
  requestId      String
  actorId        Int?
  action         String   // verb.subject e.g. "excuse.approved", "transaction.created"
  subjectType    String   // model name e.g. "AttendanceExcuse", "Transaction"
  subjectId      Int
  metadata       Json     @default("{}")
  occurredAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, occurredAt])
  @@index([organizationId, action, occurredAt])
  @@index([subjectType, subjectId])
  @@index([requestId])
}

model Transaction {
  id             Int       @id @default(autoincrement())
  organizationId Int
  type           String
  category       String
  amount         Float
  amountCents    BigInt?
  date           String
  description    String
  paymentMethod  String?
  paidTo         String?
  semester       String?
  semesterId     Int?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  semesterRef  Semester?    @relation(fields: [semesterId], references: [id], onDelete: SetNull)

  @@index([organizationId, deletedAt])
  @@index([semesterId])
}

model Budget {
  id                    Int                @id @default(autoincrement())
  organizationId        Int
  semester              String
  semesterId            Int?
  carryoverBalance      Float              @default(0)
  carryoverBalanceCents BigInt?
  reserveAmount         Float              @default(0)
  reserveAmountCents    BigInt?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  allocations           BudgetAllocation[]

  organization Organization @relation(fields: [organizationId], references: [id])
  semesterRef  Semester?    @relation(fields: [semesterId], references: [id])

  @@unique([organizationId, semester])
  @@index([organizationId])
  @@index([semesterId])
}

model BudgetAllocation {
  id       Int    @id @default(autoincrement())
  budgetId Int
  category String
  percent  Float
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, category])
  @@index([budgetId])
}

// Pinned chapter announcement shown at the top of the dashboard.
// Was a singleton (id=1); now per-org, multiple rows allowed.
model ChapterAnnouncement {
  id             Int      @id @default(autoincrement())
  organizationId Int
  title          String
  body           String
  ctaLabel       String?
  ctaUrl         String?
  authorId       Int?
  authorName     String?
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}
