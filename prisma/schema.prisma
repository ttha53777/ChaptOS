generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Brother {
  id                Int                @id @default(autoincrement())
  name              String
  role              String
  attendance        Float
  duesOwed          Float
  gpa               Float
  serviceHours      Float
  authUserId        String?            @unique @map("auth_user_id")
  isAdmin           Boolean            @default(false)
  attendanceRecords AttendanceRecord[]
  attendanceExcuses AttendanceExcuse[]
}

model Semester {
  id        Int                @id @default(autoincrement())
  label     String             @unique
  startDate String
  endDate   String
  isActive  Boolean            @default(false)
  records   AttendanceRecord[]
  excuses   AttendanceExcuse[]

  @@index([isActive])
}

model AttendanceRecord {
  id              Int           @id @default(autoincrement())
  calendarEventId Int
  brotherId       Int
  semesterId      Int
  attended        Boolean
  loggedAt        DateTime      @default(now())
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id])
  brother         Brother       @relation(fields: [brotherId], references: [id])
  semester        Semester      @relation(fields: [semesterId], references: [id])

  @@unique([calendarEventId, brotherId])
  @@index([brotherId, semesterId])
  @@index([calendarEventId, semesterId])
}

model AttendanceExcuse {
  id              Int           @id @default(autoincrement())
  calendarEventId Int
  brotherId       Int
  semesterId      Int
  reason          String
  submittedAt     DateTime      @default(now())
  isRetroactive   Boolean       @default(false)
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id])
  brother         Brother       @relation(fields: [brotherId], references: [id])
  semester        Semester      @relation(fields: [semesterId], references: [id])

  @@unique([calendarEventId, brotherId])
  @@index([brotherId, semesterId])
  @@index([calendarEventId, semesterId])
}

model Deadline {
  id      Int    @id @default(autoincrement())
  title   String
  dueDate String
  owner   String
  status  String
}

model InstagramTask {
  id      Int    @id @default(autoincrement())
  title   String
  dueDate String
  owner   String
  status  String
  type    String
}

model PartyEvent {
  id          Int       @id @default(autoincrement())
  name        String
  date        String
  partyType   String    @default("Open")
  theme       String    @default("")
  collabOrg   String    @default("")
  doorRevenue Float     @default(0)
  attendance  Int       @default(0)
  expenses    Float     @default(0)
  notes       String    @default("")
  completed   Boolean   @default(false)
  completedAt DateTime?
}

model CalendarEvent {
  id                Int                @id @default(autoincrement())
  title             String
  date              String
  time              String?
  category          String
  mandatory         Boolean
  description       String?
  location          String?
  attendanceRecords AttendanceRecord[]
  attendanceExcuses AttendanceExcuse[]

  @@index([category, date])
}

model ServiceEvent {
  id              Int      @id @default(autoincrement())
  title           String
  date            String
  location        String   @default("")
  notes           String   @default("")
  calendarEventId Int?     @unique
  createdAt       DateTime @default(now())
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  message   String
  type      String
  timestamp DateTime @default(now())
}

model Transaction {
  id            Int       @id @default(autoincrement())
  type          String
  category      String
  amount        Float
  date          String
  description   String
  paymentMethod String?
  paidTo        String?
  semester      String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([deletedAt])
}
