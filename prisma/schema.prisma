generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Brother {
  id           Int    @id @default(autoincrement())
  name         String
  role         String
  attendance   Float
  duesOwed     Float
  gpa          Float
  serviceHours Float
}

model Deadline {
  id      Int    @id @default(autoincrement())
  title   String
  dueDate String
  owner   String
  status  String
}

model InstagramTask {
  id      Int    @id @default(autoincrement())
  title   String
  dueDate String
  owner   String
  status  String
  type    String
}

model PartyEvent {
  id          Int       @id @default(autoincrement())
  name        String
  date        String
  partyType   String    @default("Open")
  theme       String    @default("")
  collabOrg   String    @default("")
  doorRevenue Float     @default(0)
  attendance  Int       @default(0)
  expenses    Float     @default(0)
  notes       String    @default("")
  completed   Boolean   @default(false)
  completedAt DateTime?
}

model CalendarEvent {
  id          Int     @id @default(autoincrement())
  title       String
  date        String
  time        String?
  category    String
  mandatory   Boolean
  description String?
  location    String?
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  message   String
  type      String
  timestamp DateTime @default(now())
}

model Transaction {
  id            Int       @id @default(autoincrement())
  type          String
  category      String
  amount        Float
  date          String
  description   String
  paymentMethod String?
  paidTo        String?
  semester      String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
