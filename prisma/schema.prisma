generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// The tenant. One row per chapter (or any org). All domain rows carry a FK here.
//
// `orgType` is the registry key from lib/org-types.ts. It drives which workflow
// template was applied at creation — enabled workflows, role seeds, vocabulary.
// Nullable so existing rows (LPE) can backfill in a follow-up migration; new
// orgs always get a value via the create-org flow.
//
// `createdByBrotherId` records which Brother provisioned the org. Nullable so
// migration-seeded orgs (LPE) don't need a synthetic creator. Not enforced
// with a FK constraint to avoid a circular Brother↔Organization dependency
// during fresh provisioning (the Brother row is created in the same transaction).
model Organization {
  id                 Int      @id @default(autoincrement())
  name               String
  slug               String   @unique
  orgType            String?
  // Public URL of the org's profile picture in Supabase Storage (org-logos
  // bucket), or null for orgs that never set one (they fall back to a gradient
  // initials badge in the sidebar/login). Set via /api/orgs/logo. Lives on the
  // hot row, not OrganizationConfig, because the sidebar reads it in the same
  // /api/auth/me round-trip as name/slug.
  logoUrl            String?
  createdByBrotherId Int?
  createdAt          DateTime @default(now())

  memberships               Membership[]
  brothers                  Brother[]
  roles                     Role[]
  semesters                 Semester[]
  attendanceExemptions      AttendanceExemption[]
  calendarEvents            CalendarEvent[]
  serviceEvents             ServiceEvent[]
  serviceParticipations     ServiceParticipation[]
  partyEvents               PartyEvent[]
  tasks                     Task[]
  taskAssignments           TaskAssignment[]
  polls                     Poll[]
  pollOptions               PollOption[]
  pollAssignments           PollAssignment[]
  pollVotes                 PollVote[]
  instagramTasks            InstagramTask[]
  docs                      Doc[]
  docFolders                DocFolder[]
  programmingEvents         ProgrammingEvent[]
  programmingEventDocs      ProgrammingEventDoc[]
  programmingChecklistItems ProgrammingChecklistItem[]
  transactions              Transaction[]
  reimbursements            Reimbursement[]
  duesPayments              DuesPayment[]
  budgets                   Budget[]
  activityLogs              ActivityLog[]
  announcements             ChapterAnnouncement[]
  operationalEvents         OperationalEvent[]
  brotherRoles              BrotherRole[]
  config                    OrganizationConfig?
  invites                   OrgInvite[]
  metricDefinitions         OrgMetricDefinition[]
}

// Per-org configuration extracted from Organization to keep the hot row small.
// One row per org (enforced by the unique constraint). Created alongside the
// Organization in the same transaction during self-serve provisioning.
//
// `enabledWorkflows` is the list of workflow registry keys the org has turned
// on (e.g. ["events", "finance", "members"]). Consumed by the sidebar, the
// dashboard, and route guards once the workflow registry ships.
//
// `vocabularyOverrides` is a sparse map of canonical-term overrides (e.g.
// { "Member": "Brother", "Period": "Semester" }). Consumed by UI components
// that respect canonical aliases. Empty by default.
//
// `thresholds` is a sparse map of the org's at-risk/watch cutoffs (attendance,
// GPA, service-hours goal). Drives every member-status badge and the health
// score. Empty {} means "use the app defaults" (lib/thresholds.ts DEFAULT_THRESHOLDS).
// Previously stored per-browser in localStorage — moved here so every officer
// shares one set of rules.
model OrganizationConfig {
  id                  Int      @id @default(autoincrement())
  organizationId      Int      @unique
  enabledWorkflows    String[] @default([])
  vocabularyOverrides Json     @default("{}")
  thresholds          Json     @default("{}")
  disabledFeatures    Json     @default("{}")
  // Org-defined extra fields (label, type, showOnRoster, etc.). See lib/custom-member-fields.ts.
  customMemberFields  Json     @default("[]")
  // Admin-chosen sidebar order — a list of nav labels (e.g. "Treasury",
  // "Docs"). Sparse and advisory: the sidebar sorts each NAV_GROUP by this list,
  // appending any labels not present (new pages, or labels the org never
  // reordered) in their default order. Empty [] means "use the default order".
  // Labels here are NOT validated against enabledWorkflows — a hidden page can
  // keep its slot so re-enabling it lands back where the admin put it. See
  // lib/nav-order.ts.
  navOrder            String[] @default([])
  // When the founder finished the post-creation setup wizard, or null while
  // setup is still in progress. This is the authoritative "is onboarding done?"
  // signal — the OrgGuard layout gates every /[slug]/* route on it being set.
  // Replaces the old proxy (enabledWorkflows.length === 0), which was never
  // empty because provisionOrg seeds workflows at creation time. Null on legacy
  // rows; backfilled to createdAt in this column's migration so existing orgs
  // aren't bounced back into onboarding.
  onboardingCompletedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Links a Brother (Supabase identity + profile) to an Organization.
// isOrgAdmin replaces Brother.isAdmin for per-org admin authority.
model Membership {
  id             Int      @id @default(autoincrement())
  brotherId      Int
  organizationId Int
  isOrgAdmin     Boolean  @default(false)
  // This person's display name *in this org*. One Google account is one Brother
  // but many Memberships, and a name is an org-local identity — the same person
  // can be "Rob" in one chapter and "Robert Chen" in another. Null means "no
  // org-specific name set", in which case every read falls back to Brother.name
  // (still the account-level canonical name). Set from the /create interview's
  // founderName, the /join redeem form, and the BrotherDrawer name edit.
  // Roster-only members (added by an admin, no auth account) have no Membership
  // row at all, so they always fall back.
  name           String?
  joinedAt       DateTime @default(now())

  brother      Brother      @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([brotherId, organizationId])
  @@index([organizationId])
}

// Platform-level super-admin (you, support staff). Distinct from per-org isOrgAdmin.
// Replaces the Brother.isAdmin boolean for platform-staff access.
model PlatformAdmin {
  id        Int     @id @default(autoincrement())
  brotherId Int     @unique
  brother   Brother @relation(fields: [brotherId], references: [id])
}

model Brother {
  id                    Int                    @id @default(autoincrement())
  organizationId        Int
  name                  String
  role                  String
  attendance            Float
  duesOwed              Float
  gpa                   Float
  serviceHours          Float
  authUserId            String?                @unique @map("auth_user_id")
  avatarUrl             String?                @map("avatar_url")
  email                 String?
  isAdmin               Boolean                @default(false)
  // "Ghost" members provisioned via the Atomic Samurai backdoor: full app access
  // but hidden from every brother listing, count, and attendance enrollment.
  isGhost               Boolean                @default(false)
  // Per-member values for org-defined custom fields. Sparse map { fieldId → value }.
  // Unknown field ids (from deleted definitions) are stripped on read by sanitizeCustomFields().
  customFields          Json                   @default("{}")
  attendanceRecords     AttendanceRecord[]
  attendanceExcuses     AttendanceExcuse[]
  attendanceExemptions  AttendanceExemption[]
  authoredLogs          ActivityLog[]
  roles                 BrotherRole[]
  memberships           Membership[]
  platformAdmin         PlatformAdmin?
  createdInvites        OrgInvite[]            @relation("InviteCreator")
  inviteRedemptions     InviteRedemption[]
  metricValues          BrotherMetricValue[]
  serviceParticipations ServiceParticipation[]
  reimbursements        Reimbursement[]
  duesPayments          DuesPayment[]
  // Ledger rows attributed to this member — dues payments. Without this link,
  // "does the roster agree with the ledger?" is a question the DB cannot answer.
  transactions          Transaction[]
  taskAssignments       TaskAssignment[]
  pollAssignments       PollAssignment[]
  pollVotes             PollVote[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// An admin-generated invite link for an org. Anyone with the link can join until
// it expires or is revoked (reusable, multi-use).
//
//   mode      "open"  → redeeming creates a fresh Brother + Membership.
//             "claim" → redeeming routes the user into the name-match claim flow.
//   expiresAt null    → never expires.
//   revokedAt null    → still active.
//
// `token` is stored in plaintext: it's a bearer credential that already lives in
// the URL/clipboard/chat, so hashing it (vs a password) buys little here. If a
// DB-dump threat model emerges, switch to storing sha256(token) and looking up
// by hash. @unique gives a single-query lookup.
model OrgInvite {
  id                 Int       @id @default(autoincrement())
  organizationId     Int
  token              String    @unique
  mode               String // InviteMode union in @/lib/state
  expiresAt          DateTime?
  revokedAt          DateTime?
  createdByBrotherId Int
  createdAt          DateTime  @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    Brother            @relation("InviteCreator", fields: [createdByBrotherId], references: [id])
  redemptions  InviteRedemption[]

  @@index([organizationId])
}

// One row per successful join through an OrgInvite — the audit trail + the
// settings redemption count. @@unique makes re-clicking a link idempotent.
model InviteRedemption {
  id         Int      @id @default(autoincrement())
  inviteId   Int
  brotherId  Int
  redeemedAt DateTime @default(now())

  invite  OrgInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  brother Brother   @relation(fields: [brotherId], references: [id], onDelete: Cascade)

  @@unique([inviteId, brotherId])
  @@index([inviteId])
}

// Discord-style role: a named bundle of permission bits with a hierarchy rank.
// name is unique per org (not globally) — two orgs may both have a "President" role.
model Role {
  id             Int           @id @default(autoincrement())
  organizationId Int
  name           String
  // Optional hex color (e.g. "#5865F2") for the UI chip; null = neutral.
  color          String?
  // Hierarchy rank. A caller can only grant/edit roles whose rank is STRICTLY
  // LESS than their own highest assigned role's rank. Higher = more authority.
  rank           Int           @default(0)
  // Bitfield of PERMISSIONS flags (see lib/permissions.ts).
  permissions    Int           @default(0)
  // System roles are seeded by migration and protected from deletion/rename.
  isSystem       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  brothers       BrotherRole[]
  taskAssignments TaskAssignment[]
  pollAssignments PollAssignment[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@index([organizationId, rank])
}

// Join table: a brother can hold any number of roles. Their effective
// permission bitfield is the bitwise OR of every assigned role's `permissions`.
// organizationId is denormalized here so the table is self-contained for org
// isolation — prevents a user from assigning roles that belong to a different org.
model BrotherRole {
  brotherId      Int
  roleId         Int
  organizationId Int
  assignedAt     DateTime     @default(now())
  brother        Brother      @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@id([brotherId, roleId])
  @@index([roleId])
  @@index([organizationId])
}

model Semester {
  id             Int                @id @default(autoincrement())
  organizationId Int
  label          String
  startDate      String
  endDate        String
  isActive       Boolean            @default(false)
  records        AttendanceRecord[]
  excuses        AttendanceExcuse[]
  exemptions     AttendanceExemption[]
  transactions   Transaction[]
  budgets        Budget[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, label])
  @@index([organizationId, isActive])
}

model AttendanceRecord {
  id              Int           @id @default(autoincrement())
  calendarEventId Int
  brotherId       Int
  semesterId      Int
  attended        Boolean
  loggedAt        DateTime      @default(now())
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id])
  brother         Brother       @relation(fields: [brotherId], references: [id])
  semester        Semester      @relation(fields: [semesterId], references: [id])

  @@unique([calendarEventId, brotherId])
  @@index([brotherId, semesterId])
  @@index([calendarEventId, semesterId])
}

model AttendanceExcuse {
  id              Int           @id @default(autoincrement())
  calendarEventId Int
  brotherId       Int
  semesterId      Int
  reason          String
  submittedAt     DateTime      @default(now())
  isRetroactive   Boolean       @default(false)
  status          String        @default("approved")
  decidedById     Int?
  decidedAt       DateTime?
  rejectionNote   String?
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id])
  brother         Brother       @relation(fields: [brotherId], references: [id])
  semester        Semester      @relation(fields: [semesterId], references: [id])

  @@unique([calendarEventId, brotherId])
  @@index([brotherId, semesterId])
  @@index([calendarEventId, semesterId])
  @@index([status])
}

// A member marked exempt from mandatory-attendance tracking for a whole semester
// (studying abroad, co-op, inactive, etc.). Exempt members drop out of every
// mandatory event's eligible set for that semester — no per-event excuse needed —
// and are excluded from the chapter-wide attendance ratio (their Brother.attendance
// is set to the -1 "exempt" sentinel by the recalc). Carries organizationId
// directly (org-scoped like Poll), so isolation is a plain WHERE, not a relation join.
model AttendanceExemption {
  id             Int          @id @default(autoincrement())
  organizationId Int
  brotherId      Int
  semesterId     Int
  reason         String       @default("inactive")
  note           String?
  createdById    Int?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  brother        Brother      @relation(fields: [brotherId], references: [id])
  semester       Semester     @relation(fields: [semesterId], references: [id])

  @@unique([semesterId, brotherId])
  @@index([organizationId, semesterId])
}

// A task is a unit of work handed out to members and/or roles. A task WITH a
// dueDate is what the UI calls a "deadline" (it folds into the timeline); a task
// without one is a loose to-do. Status is just open/done — urgency (urgent/due
// soon/upcoming) is COMPUTED from dueDate at render time, never stored. Anyone
// assigned can mark the shared status done; only MANAGE_TASKS can edit/reassign.
model Task {
  id             Int       @id @default(autoincrement())
  organizationId Int
  title          String
  dueDate        String? // ISO YYYY-MM-DD; null = undated to-do
  status         String    @default("open") // TaskStatus union in @/lib/state: "open" | "done"
  notes          String?
  createdById    Int? // Brother who created it; null for rows migrated from legacy Deadlines
  completedById  Int?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  assignments  TaskAssignment[]

  @@index([organizationId])
  @@index([organizationId, status])
}

// Join: a task targets one-or-more brothers AND/OR one-or-more roles. Role
// targets resolve to current holders at READ time (not snapshotted), so adding
// someone to a role auto-assigns them the role's open tasks. organizationId is
// denormalized for self-contained org isolation (mirrors BrotherRole). Exactly
// one of brotherId/roleId is set (CHECK constraint in the migration).
model TaskAssignment {
  id             Int @id @default(autoincrement())
  taskId         Int
  organizationId Int
  brotherId      Int?
  roleId         Int?

  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  brother      Brother?     @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([taskId])
  @@index([organizationId, brotherId])
  @@index([organizationId, roleId])
}

// A poll is task-shaped (attach members/roles + an optional date) but adds a
// question with 2-10 options that attached members vote on. Single-choice: one
// vote per voter (PollVote @@unique). Results are live; closing locks voting but
// keeps results visible. status is open/closed (PollStatus union in @/lib/state).
model Poll {
  id             Int       @id @default(autoincrement())
  organizationId Int
  question       String
  closeDate      String? // ISO YYYY-MM-DD; null = no date (mirrors Task.dueDate)
  status         String    @default("open") // PollStatus: "open" | "closed"
  createdById    Int?
  closedById     Int?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  options      PollOption[]
  assignments  PollAssignment[]
  votes        PollVote[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model PollOption {
  id             Int    @id @default(autoincrement())
  organizationId Int
  pollId         Int
  label          String
  position       Int    @default(0) // display order

  poll         Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  votes        PollVote[]

  @@index([pollId])
  @@index([organizationId])
}

// Join: mirrors TaskAssignment. Exactly one of brotherId/roleId per row (CHECK
// constraint in the migration). Role targets resolve to current holders at READ
// time, so a member granted a role gains the right to vote on its open polls.
model PollAssignment {
  id             Int @id @default(autoincrement())
  pollId         Int
  organizationId Int
  brotherId      Int?
  roleId         Int?

  poll         Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  brother      Brother?     @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([pollId])
  @@index([organizationId, brotherId])
  @@index([organizationId, roleId])
}

// One row per voter per poll (single-choice). Re-voting updates optionId via
// upsert on @@unique([pollId, brotherId]). Keyed to the poll, not the
// assignment, so a vote survives the voter later being un-assigned.
model PollVote {
  id             Int      @id @default(autoincrement())
  organizationId Int
  pollId         Int
  optionId       Int
  brotherId      Int // who voted
  createdAt      DateTime @default(now())

  poll         Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option       PollOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  brother      Brother      @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([pollId, brotherId])
  @@index([pollId])
  @@index([optionId])
}

model InstagramTask {
  id             Int    @id @default(autoincrement())
  organizationId Int
  title          String
  dueDate        String
  // The actual day the post went live. Null until posted; set when a post is
  // marked posted (defaults to dueDate) and independently editable. dueDate
  // stays the planned/target date that drives urgency.
  postedDate     String?
  status         String @default("open") // "open" | "posted" — urgency is computed from dueDate, never stored
  type           String
  // Optional soft reference to the event this post promotes. Not a date
  // constraint — the post keeps its own dueDate. SetNull so deleting the event
  // just clears the link (the post survives).
  calendarEventId Int?

  organization  Organization   @relation(fields: [organizationId], references: [id])
  calendarEvent CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([calendarEventId])
}

// A pinned external resource (Google Doc, website, shared drive folder, …)
// shown on the Docs page. We cache OG metadata so cards can fall back to a
// thumbnail when the destination refuses to load in an iframe.
model Doc {
  id             Int      @id @default(autoincrement())
  organizationId Int
  title          String
  url            String
  description    String?
  // Cached metadata, refreshed on create / URL change. `embedOk = null` means
  // we haven't probed yet; `false` means the site sent X-Frame-Options or a
  // frame-ancestors CSP that blocks our origin → render the OG image instead.
  ogImage        String?
  ogTitle        String?
  faviconUrl     String?
  embedOk        Boolean?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    Int?
  // Library folder this doc lives in. null = library root (no folder).
  folderId       Int?
  // Pinned / favorite. null = not pinned; a timestamp floats the doc to the top
  // of the library ahead of the chosen sort, most-recently pinned first.
  pinnedAt       DateTime?
  // Manual drag-order within a section, only honored under the "manual" library
  // sort. null = never hand-ordered → sorts after positioned docs by newest.
  position       Int?

  organization           Organization          @relation(fields: [organizationId], references: [id])
  folder                 DocFolder?            @relation(fields: [folderId], references: [id])
  programmingLinks       ProgrammingEventDoc[]
  programmingAttachments ProgrammingEvent[]

  @@index([organizationId, createdAt])
  @@index([organizationId, folderId])
  @@index([organizationId, pinnedAt])
}

// A flat (one-level) folder for grouping Docs on the /docs page, à la Google
// Drive. Docs reference it via Doc.folderId; deleting a folder releases its docs
// back to the library root rather than cascading the docs away.
model DocFolder {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    Int?
  // Pinned / favorite. null = not pinned; a timestamp floats the folder to the
  // top of the library ahead of unpinned folders, most-recently pinned first.
  pinnedAt       DateTime?
  // Manual drag-order among unpinned folders. null = never hand-ordered → sorts
  // after positioned folders by name. Pinned folders float ahead regardless.
  position       Int?

  organization Organization @relation(fields: [organizationId], references: [id])
  docs         Doc[]

  @@index([organizationId, name])
  @@index([organizationId, pinnedAt])
}

model PartyEvent {
  id             Int       @id @default(autoincrement())
  organizationId Int
  name           String
  date           String
  partyType      String    @default("Open")
  theme          String    @default("")
  collabOrg      String    @default("")
  doorRevenue    Float     @default(0)
  attendance     Int       @default(0)
  expenses       Float     @default(0)
  notes          String    @default("")
  completed      Boolean   @default(false)
  completedAt    DateTime?

  // Optional backing calendar event that holds this party's member roll. Created
  // lazily on wrap-up when attendance is first recorded; attendance flows through
  // the shared AttendanceRecord system keyed to this event. Null until rolled.
  attendanceEventId Int?           @unique
  attendanceEvent   CalendarEvent? @relation("PartyAttendance", fields: [attendanceEventId], references: [id], onDelete: SetNull)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model CalendarEvent {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  title             String
  date              String
  time              String?
  category          String
  mandatory         Boolean
  description       String?
  location          String?
  notesSummary      String?
  notesSummaryAt    DateTime?
  notesUpdatedAt    DateTime?
  // Used by the Programming page (events workflow). Chapter/Timeline rows keep defaults.
  owner             String             @default("")
  status            String             @default("Upcoming")
  attendanceRecords AttendanceRecord[]
  attendanceExcuses AttendanceExcuse[]
  programmingEvent  ProgrammingEvent?
  partyEvent        PartyEvent?        @relation("PartyAttendance")
  transactionLinks  TransactionCalendarEvent[]
  instagramTasks    InstagramTask[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, category, date])
}

model ProgrammingEvent {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  calendarEventId Int?     @unique
  // Owning planning fields. A CalendarEvent is created only once the event
  // leaves the "idea" stage (Planning+); until then these live here alone.
  title           String
  date            String?
  category        String
  location        String?
  time            String?
  description     String?
  status          String   @default("Upcoming")
  stage           String   @default("idea")
  mandatory       Boolean  @default(false)
  // Prep / ops fields.
  owner           String   @default("")
  collabOrg       String   @default("")
  itineraryUrl    String? // deprecated — backfilled into attachmentUrl
  attachmentUrl   String?
  attachmentDocId Int?
  roomStatus      String   @default("not_submitted")
  itineraryNotNeeded Boolean @default(false) // marks the itinerary prep item done without a file
  flyerPosted     Boolean  @default(false)
  socialsMeeting  Boolean  @default(false)
  spendingCents   Int      @default(0)
  successRating   Int?
  wrapUpNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization               @relation(fields: [organizationId], references: [id])
  calendarEvent CalendarEvent?             @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  attachmentDoc Doc?                       @relation(fields: [attachmentDocId], references: [id], onDelete: SetNull)
  docs          ProgrammingEventDoc[]
  checklist     ProgrammingChecklistItem[]

  @@index([organizationId, calendarEventId])
  @@index([organizationId, stage])
  @@index([organizationId, date])
}

model ProgrammingChecklistItem {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  programmingEventId Int
  label              String
  done               Boolean  @default(false)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  programmingEvent ProgrammingEvent @relation(fields: [programmingEventId], references: [id], onDelete: Cascade)

  @@index([organizationId, programmingEventId])
}

model ProgrammingEventDoc {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  programmingEventId Int
  docId              Int
  createdAt          DateTime @default(now())

  organization     Organization     @relation(fields: [organizationId], references: [id])
  programmingEvent ProgrammingEvent @relation(fields: [programmingEventId], references: [id], onDelete: Cascade)
  doc              Doc              @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@unique([programmingEventId, docId])
  @@index([organizationId, programmingEventId])
  @@index([organizationId, docId])
}

model ServiceEvent {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  title           String
  date            String
  location        String   @default("")
  notes           String   @default("")
  calendarEventId Int?     @unique
  createdAt       DateTime @default(now())

  organization   Organization           @relation(fields: [organizationId], references: [id])
  participations ServiceParticipation[]

  @@index([organizationId])
}

// One row per (member, service event): the hours that member earned at that
// event. The source of truth for Brother.serviceHours, which is recomputed as
// SUM(hours) by the recalc-service-hours event handler — mirroring how
// Brother.attendance is derived from AttendanceRecord rows. Cascade-deletes with
// either parent so totals never reference an orphaned event/member.
model ServiceParticipation {
  id             Int      @id @default(autoincrement())
  organizationId Int
  serviceEventId Int
  brotherId      Int
  hours          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  serviceEvent ServiceEvent @relation(fields: [serviceEventId], references: [id], onDelete: Cascade)
  brother      Brother      @relation(fields: [brotherId], references: [id], onDelete: Cascade)

  @@unique([serviceEventId, brotherId])
  @@index([organizationId])
  @@index([brotherId])
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  organizationId Int
  message        String
  type           String
  timestamp      DateTime @default(now())
  actorId        Int?
  actor          Brother? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
  @@index([actorId])
}

// Structured operational event log. The raw fact-stream from which the UI
// activity feed, audit log, analytics, notifications, and AI context are
// projected. Free-text ActivityLog rows are dual-written from logActivity()
// for backwards-compat until Phase 3 cuts the UI over to event projections.
model OperationalEvent {
  id             BigInt   @id @default(autoincrement())
  organizationId Int
  requestId      String
  actorId        Int?
  action         String // verb.subject e.g. "excuse.approved", "transaction.created"
  subjectType    String // model name e.g. "AttendanceExcuse", "Transaction"
  subjectId      Int
  metadata       Json     @default("{}")
  occurredAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, occurredAt])
  @@index([organizationId, action, occurredAt])
  @@index([subjectType, subjectId])
  @@index([requestId])
}

model Transaction {
  id             Int       @id @default(autoincrement())
  organizationId Int
  type           String
  category       String
  amount         Float
  amountCents    BigInt?
  date           String
  description    String
  paymentMethod  String?
  semester       String?
  semesterId     Int?
  status         String    @default("posted")
  // The member this row is attributable to. Only dues payments carry it today —
  // most spend (a Costco run) belongs to no one member. SetNull on delete: removing
  // someone from the roster must not erase the record that they paid.
  brotherId      Int?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization    Organization              @relation(fields: [organizationId], references: [id])
  semesterRef     Semester?                 @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  brother         Brother?                  @relation(fields: [brotherId], references: [id], onDelete: SetNull)
  calendarEvents  TransactionCalendarEvent[]
  reimbursement   Reimbursement?
  duesPayment     DuesPayment?

  @@index([organizationId, deletedAt])
  @@index([semesterId])
  @@index([organizationId, brotherId])
}

model TransactionCalendarEvent {
  transactionId   Int
  calendarEventId Int

  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  calendarEvent CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)

  @@id([transactionId, calendarEventId])
  @@index([calendarEventId])
}

model Reimbursement {
  id             Int      @id @default(autoincrement())
  organizationId Int
  brotherId      Int
  amount         Float
  amountCents    BigInt?
  date           String
  description    String
  category       String?
  status         String   @default("pending")
  rejectionNote  String?
  // Set when the request is approved: the expense row it minted in the ledger.
  // Nothing else links the two books, so every balance in the app is blind to an
  // approved payout until this exists.
  transactionId  Int?     @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brother      Brother      @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([brotherId])
  @@index([organizationId, status])
}

// A submitted dues payment awaiting treasury sign-off. Nothing moves on either book —
// not Brother.duesOwed, not the Transaction ledger — until this flips to "approved":
// see updateDuesPayment in lib/services/dues-service.ts, which mints the transaction
// and decrements duesOwed atomically at that moment, not at submission.
model DuesPayment {
  id             Int      @id @default(autoincrement())
  organizationId Int
  brotherId      Int
  amount         Float
  amountCents    BigInt?
  date           String
  paymentMethod  String?
  status         String   @default("pending")
  rejectionNote  String?
  // Set when approved: the income row it minted in the ledger.
  transactionId  Int?     @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brother      Brother      @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([brotherId])
  @@index([organizationId, status])
}

model Budget {
  id                    Int                @id @default(autoincrement())
  organizationId        Int
  semester              String
  semesterId            Int?
  carryoverBalance      Float              @default(0)
  carryoverBalanceCents BigInt?
  reserveAmount         Float              @default(0)
  reserveAmountCents    BigInt?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  allocations           BudgetAllocation[]

  organization Organization @relation(fields: [organizationId], references: [id])
  semesterRef  Semester?    @relation(fields: [semesterId], references: [id])

  @@unique([organizationId, semester])
  @@index([organizationId])
  @@index([semesterId])
}

model BudgetAllocation {
  id       Int    @id @default(autoincrement())
  budgetId Int
  category String
  percent  Float
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, category])
  @@index([budgetId])
}

// Org-defined custom metric (e.g. "Practice Reps", "Books Read").
// Definitions are soft-deleted (deletedAt) to preserve BrotherMetricValue rows.
// slug is immutable after creation and unique per org — used as the stable key
// in API paths and AI tool references.
model OrgMetricDefinition {
  id             Int       @id @default(autoincrement())
  organizationId Int
  slug           String // kebab-case, max 50 chars — immutable after create
  name           String // display label, max 40 chars
  unit           String? // optional suffix: "hrs", "reps", "%" — null = bare number
  goal           Float // per-member target; "on track" means value >= goal
  atRiskBelow    Float // value < atRiskBelow → "at_risk"
  watchBelow     Float? // optional: atRiskBelow <= value < watchBelow → "watch"
  aggregation    String // "avg" | "sum" | "count_on_track"
  displayOrder   Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values       BrotherMetricValue[]

  @@unique([organizationId, slug])
  @@index([organizationId, deletedAt])
}

// Per-member value for a custom metric. organizationId is denormalized (same
// pattern as BrotherRole) so the tenant wrapper can scope without a join.
model BrotherMetricValue {
  id                 Int      @id @default(autoincrement())
  brotherId          Int
  metricDefinitionId Int
  organizationId     Int // denormalized for tenant scoping
  value              Float
  updatedAt          DateTime @updatedAt

  brother    Brother             @relation(fields: [brotherId], references: [id], onDelete: Cascade)
  definition OrgMetricDefinition @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)

  @@unique([brotherId, metricDefinitionId])
  @@index([organizationId, metricDefinitionId])
  @@index([brotherId])
}

// Pinned chapter announcement shown at the top of the dashboard.
// One row per org (enforced by the unique constraint below).
model ChapterAnnouncement {
  id             Int      @id @default(autoincrement())
  organizationId Int
  title          String
  body           String
  ctaLabel       String?
  ctaUrl         String?
  authorId       Int?
  authorName     String?
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId])
}
