{
  "name": "figurints-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint:prisma": "bash scripts/lint-direct-prisma.sh",
    "lint:prisma:strict": "bash scripts/lint-direct-prisma.sh --strict",
    "lint:services": "bash scripts/check-raw-prisma.sh",
    "lint:modules": "bash scripts/lint-module-boundaries.sh",
    "lint:modules:strict": "bash scripts/lint-module-boundaries.sh --strict",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:chat": "tsx scripts/eval-ask-the-chapter.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "next": "16.2.6",
    "obscenity": "^0.4.6",
    "openai": "^6.39.0",
    "pg": "^8.20.0",
    "pluralize": "^8.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
